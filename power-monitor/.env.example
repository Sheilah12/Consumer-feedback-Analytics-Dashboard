# Neon Postgres (use the POOLED connection string from Vercel + Neon integration)
DATABASE_URL=postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require

# Device webhook authentication (?secret= on POST /api/blynk/webhook)
INGEST_SECRET=change-me-to-a-long-random-string

# Guards POST /api/config, DELETE /api/alerts, alert ack
ADMIN_TOKEN=

# Auto-provisioned by Vercel for cron jobs
CRON_SECRET=

# Optional — only used by GET /api/blynk/test
BLYNK_TOKEN=
BLYNK_SERVER=https://blynk.cloud

ALERT_THRESHOLD_MA=150
CONSECUTIVE_SAMPLES=2
TARIFF_KWH_COST=25.0
CURRENCY=KES
RETENTION_DAYS=30
